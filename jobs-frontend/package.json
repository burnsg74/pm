{
  "name": "jobs-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "start": "concurrently \"npm run start:frontend\" \"DEBUG=vite:* npm run start:backend\"",
    "start:frontend": "vite --open",
    "start:backend": "cd ../jobs-backend && NODE_ENV=development npm run dev",
    "scrap:indeed": "cd ../jobs-scraper && npm run scrap:indeed",
    "check:pakcages": "npx depcheck"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.2",
